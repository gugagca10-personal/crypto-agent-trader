# ============================================================
# BINANCE API
# Crie em: https://www.binance.com/en/my/settings/api-management
# Permissões necessárias: Enable Reading + Enable Spot & Margin Trading
# ============================================================
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true   # Mude para false em produção (use testnet.binance.vision para testes)

# ============================================================
# ANTHROPIC / CLAUDE API
# Obtenha em: https://console.anthropic.com/settings/keys
# ============================================================
ANTHROPIC_API_KEY=
# Modelos disponíveis (mais barato → mais capaz):
#   claude-haiku-4-5-20251001   ← padrão (recomendado, ~$0.01/dia)
#   claude-sonnet-4-6           ← mais inteligente (~$0.14/dia)
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ============================================================
# CLOUDFLARE R2 (opcional — para logs de trades na nuvem)
# Console: https://dash.cloudflare.com → R2 → Manage R2 API tokens
# ============================================================
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=crypto-trader-logs

# ============================================================
# CONFIGURAÇÃO DE TRADING
# ============================================================
INITIAL_USDT_BALANCE=20
MAX_TRADE_PERCENTAGE=0.30        # Máx 30% do saldo por trade
STOP_LOSS_PERCENTAGE=0.04        # Stop loss em 4% (fallback se IA não sugerir)
TAKE_PROFIT_PERCENTAGE=0.08      # Take profit em 8% (fallback)
MIN_AI_CONFIDENCE=70             # Só executa se IA tiver >= 70% de confiança
MAX_OPEN_POSITIONS=2             # Máx 2 posições abertas simultâneas
EXCLUDED_SYMBOLS=BTC,GUN        # NUNCA negociar esses ativos
TOP_PAIRS_COUNT=20               # Analisa top 20 pares USDT por volume

# ============================================================
# OPERACIONAL
# ============================================================
DRY_RUN=true                     # true = simulação | false = trading real
LOG_LEVEL=INFO                   # DEBUG, INFO, WARNING, ERROR
ANALYSIS_INTERVAL_MINUTES=15    # Ciclo de análise a cada 15 min
POSITION_CHECK_INTERVAL_SECONDS=60  # Verifica stop/take profit a cada 60s
