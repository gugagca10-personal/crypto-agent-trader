# ============================================================
# AFTER EDITING THIS FILE, RUN:    chmod 600 .env
# This restricts read access to your user only.
# ============================================================

# ============================================================
# BINANCE API
# Crie em: https://www.binance.com/en/my/settings/api-management
# Permissões necessárias: Enable Reading + Enable Spot & Margin Trading
# NUNCA habilite Withdrawals. Sempre defina IP allowlist.
# ============================================================
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true   # Mude para false em produção (use testnet.binance.vision para testes)

# ============================================================
# ANTHROPIC / CLAUDE API
# Obtenha em: https://console.anthropic.com/settings/keys
# ============================================================
ANTHROPIC_API_KEY=
# Modelos disponíveis (mais barato → mais capaz):
#   claude-haiku-4-5-20251001   ← padrão (recomendado, ~$0.01/dia)
#   claude-sonnet-4-6           ← mais inteligente (~$0.14/dia)
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ============================================================
# CLOUDFLARE R2 (opcional — para logs de trades na nuvem)
# Console: https://dash.cloudflare.com → R2 → Manage R2 API tokens
# ============================================================
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=crypto-trader-logs

# ============================================================
# CONFIGURAÇÃO DE TRADING
# ============================================================
INITIAL_USDT_BALANCE=20
MAX_TRADE_PERCENTAGE=0.30        # Teto por trade — sizing real divide saldo×80% pelos slots
STOP_LOSS_PERCENTAGE=0.04        # Fallback se ATR e IA não fornecerem stop
TAKE_PROFIT_PERCENTAGE=0.08      # Fallback se ATR e IA não fornecerem take
MIN_AI_CONFIDENCE=60             # Confiança mínima da IA para executar
MAX_OPEN_POSITIONS=3             # Teto de posições simultâneas (escala com saldo)
EXCLUDED_SYMBOLS=BTC,GUN         # NUNCA negociar esses ativos
TOP_PAIRS_COUNT=50               # 70% top volume + 30% top movers 24h

# ============================================================
# OPERACIONAL
# ============================================================
DRY_RUN=true                     # true = simulação | false = trading real
LOG_LEVEL=INFO                   # DEBUG, INFO, WARNING, ERROR
ANALYSIS_INTERVAL_MINUTES=5      # Ciclo de análise a cada 5 min (alts são rápidas)
POSITION_CHECK_INTERVAL_SECONDS=30  # Verifica SL/TP/trailing a cada 30s
